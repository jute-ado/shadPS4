{
  "schemaVersion": 1,
  "emulator": "../build/shadps4",
  "cases": [
    {
      "name": "CUSA00000 survives initial boot",
      "gamePath": "installed-games/CUSA00000",
      "timeoutSeconds": 30,
      "useIpc": true,
      "screenshotSeconds": [
        10
      ],
      "minimumDistinctScreenshots": 1,
      "buttonEvents": [
        {
          "seconds": 5,
          "button": "cross",
          "pressed": true
        },
        {
          "seconds": 5.1,
          "button": "cross",
          "pressed": false
        }
      ],
      "axisEvents": [
        {
          "seconds": 6,
          "axis": "left_x",
          "value": 255
        },
        {
          "seconds": 7,
          "axis": "left_x",
          "value": 128
        }
      ],
      "args": [
        "--config-clean"
      ],
      "allowedOutcomes": [
        "timed_out"
      ],
      "requiredLogPatterns": [
        "Starting shadps4 emulator"
      ],
      "forbiddenLogPatterns": [
        "Unhandled exception",
        "Assertion Failed"
      ]
    }
  ]
}
